{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebSearch",
      "Bash(wget -qO /tmp/github.ico \"https://icons.duckduckgo.com/ip3/github.com.ico\")",
      "Read(//tmp/**)",
      "Bash(wget -qO /tmp/proton.ico \"https://icons.duckduckgo.com/ip3/mail.proton.me.ico\")",
      "Bash(nos test *)",
      "WebFetch(domain:stackoverflow.com)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false
  }
}
