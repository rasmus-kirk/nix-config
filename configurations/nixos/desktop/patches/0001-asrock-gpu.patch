 }   /* DetectSMBusPolychromeControllers() */
 
+/******************************************************************************************\
+*                                                                                          *
+*   DetectASRockGPUSMBusControllers                                                        *
+*                                                                                          *
+*       Detect ASRock GPU RGB controllers on AMD GPU I2C buses at address 0x36             *
+*       Based on SignalRGB ASRock GPU.js plugin                                            *
+*                                                                                          *
+\******************************************************************************************/
+
+void DetectASRockGPUSMBusControllers(std::vector<i2c_smbus_interface*>& busses)
+{
+    for(unsigned int bus = 0; bus < busses.size(); bus++)
+    {
+        /*-----------------------------------------------------*\
+        | Check if this is an AMD GPU bus (from SignalRGB)      |
+        \*-----------------------------------------------------*/
+        if(busses[bus]->pci_vendor == AMD_GPU_VEN)
+        {
+            /*-----------------------------------------------------*\
+            | Check if it's an ASRock card (SubVendor 0x1849)       |
+            \*-----------------------------------------------------*/
+            if(busses[bus]->pci_subsystem_vendor == ASROCK_SUB_VEN)
+            {
+                LOG_DEBUG("[ASRock GPU] Checking AMD GPU bus %d for ASRock RGB controller at 0x%02X", bus, ASROCK_GPU_SMBUS_ADDRESS);
+                
+                /*-----------------------------------------------------*\
+                | Test for device at 0x36 (from SignalRGB)              |
+                \*-----------------------------------------------------*/
+                int res = busses[bus]->i2c_smbus_write_quick(ASROCK_GPU_SMBUS_ADDRESS, I2C_SMBUS_WRITE);
+                
+                if(res >= 0)
+                {
+                    LOG_DEBUG("[ASRock GPU] Device responded at 0x%02X, creating controller", ASROCK_GPU_SMBUS_ADDRESS);
+                    
+                    ASRockGPUSMBusController* controller = new ASRockGPUSMBusController(busses[bus], ASROCK_GPU_SMBUS_ADDRESS);
+                    
+                    if(controller->DetectChannels())
+                    {
+                        RGBController_ASRockGPUSMBus* rgb_controller = new RGBController_ASRockGPUSMBus(controller);
+                        ResourceManager::get()->RegisterRGBController(rgb_controller);
+                    }
+                    else
+                    {
+                        LOG_WARNING("[ASRock GPU] No active channels found, device not registered");
+                        delete controller;
+                    }
+                }
+                else
+                {
+                    LOG_DEBUG("[ASRock GPU] No response at address 0x%02X", ASROCK_GPU_SMBUS_ADDRESS);
+                }
+            }
+        }
+    }
+}   /* DetectASRockGPUSMBusControllers() */
+
 REGISTER_I2C_DETECTOR("ASRock Motherboard SMBus Controllers", DetectASRockSMBusControllers);
+REGISTER_I2C_DETECTOR("ASRock GPU SMBus Controllers", DetectASRockGPUSMBusControllers);
